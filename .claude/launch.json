{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend API (dev)",
      "cwd": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Mobile (Expo)",
      "cwd": "mobile",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 8081
    },
    {
      "name": "Mobile (Expo Android)",
      "cwd": "mobile",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "android"],
      "port": 8081,
      "autoPort": true
    }
  ]
}
